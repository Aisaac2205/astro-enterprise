---
import Layout from "../layouts/Layout.astro";
import FlowDiagram from "../features/architecture/FlowDiagram.astro";
import TechSpecs from "../features/architecture/TechSpecs.astro";
import Icon from "../components/ui/Icon";
import PageHero from "../components/ui/PageHero.astro";
---

<Layout title="Arquitectura | DocScan">
    <PageHero
        badge="Infraestructura Técnica"
        title="Motor OCR Dual:"
        titleAccent="Cloud + On-Premise"
        description="Arquitectura híbrida con procesamiento en la nube (Gemini Flash Lite) y local (LM Studio). Diseñada para máxima privacidad, escalabilidad y disponibilidad."
        bottomOverlayClass="from-surface-page"
    />

    <!-- Flow Diagrams -->
    <FlowDiagram />

    <!-- Tech Specs Grid -->
    <TechSpecs />

    <!-- CTA Section -->
    <section class="py-24 bg-brand-ink-900 relative overflow-hidden">
        <!-- Glow -->
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-accent-500/5 rounded-full blur-[100px] pointer-events-none"
        >
        </div>

        <div class="container mx-auto px-4 relative z-10">
            <div
                class="max-w-3xl mx-auto border border-white/10 p-12 bg-white/5 backdrop-blur-sm text-center"
            >
                <div
                    class="w-16 h-16 bg-accent-500/10 text-accent-500 flex items-center justify-center mx-auto mb-6"
                >
                    <Icon name="Cpu" className="w-8 h-8" client:only="react" />
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
                    ¿Listo para conocer nuestra infraestructura?
                </h2>
                <p
                    class="text-neutral-400 text-lg mb-8 font-light leading-relaxed"
                >
                    Solicite una revisión técnica personalizada y conozca cómo
                    nuestra arquitectura dual garantiza la seguridad, privacidad
                    y disponibilidad de sus documentos.
                </p>
                <div class="flex flex-col md:flex-row justify-center gap-4">
                    <a
                        href="https://wa.me/50237220606?text=Hola,%20me%20gustaría%20solicitar%20una%20demostración%20personalizada%20de%20DocScan,%20su%20sistema%20OCR%20con%20IA.%20Quedo%20a%20la%20espera%20de%20su%20respuesta."
                        target="_blank"
                        rel="noopener noreferrer"
                        class="bg-white text-brand-ink-900 px-10 py-4 font-semibold hover:bg-neutral-200 transition-all min-w-[200px]"
                    >
                        Solicitar Demo
                    </a>
                    <a
                        href="/servicios"
                        class="bg-white/10 text-white px-10 py-4 font-semibold hover:bg-white/20 transition-all min-w-[200px] border border-white/20"
                    >
                        Ver Servicios
                    </a>
                </div>
                <p class="text-sm text-neutral-500 mt-8">
                    <Icon
                        name="ShieldCheck"
                        className="w-4 h-4 inline-block mr-1 text-accent-500"
                        client:only="react"
                    />
                    ISO 27001 · GDPR · SOC 2 · Uptime 99.99%
                </p>
            </div>
        </div>
    </section>
</Layout>
