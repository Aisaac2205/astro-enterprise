---
interface Props {
    icon: string;
    color: string;
    diagramType: string;
    title: string;
    description: string;
    specs?: Array<{ label: string; value: string }>;
    iconComponent: any;
}

const { icon, color, diagramType, title, description, specs, iconComponent: Icon } = Astro.props;
---

<div>
    <div class="flex items-center gap-4 mb-5">
        <div class="w-12 h-12 rounded-xl bg-surface-sunken border border-border flex items-center justify-center">
            <Icon
                name={icon}
                className={`w-6 h-6 ${color}`}
            />
        </div>
        <div class="flex flex-col">
            <span class="text-[10px] font-mono font-bold uppercase tracking-widest text-fg-tertiary">
                {diagramType}
            </span>
            <span class="text-[10px] font-mono text-accent-500 uppercase tracking-widest">
                DOCSCAN ENGINE
            </span>
        </div>
    </div>

    <h3 class="text-2xl md:text-3xl font-bold text-fg-primary mb-4 tracking-tight">
        {title}
    </h3>

    <p class="text-fg-secondary leading-relaxed text-base mb-6 font-light">
        {description}
    </p>

    {/* Inline specs preview */}
    {
        specs && (
            <div class="space-y-2">
                {specs.map((spec) => (
                    <div class="flex items-center justify-between py-2 border-b border-border-subtle">
                        <span class="text-xs text-fg-tertiary font-medium">
                            {spec.label}
                        </span>
                        <span class="text-xs font-mono text-accent-500 font-semibold">
                            {spec.value}
                        </span>
                    </div>
                ))}
            </div>
        )
    }
</div>
