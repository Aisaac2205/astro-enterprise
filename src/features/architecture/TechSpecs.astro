---
import { getCollection } from "astro:content";
import Icon from "../../components/ui/Icon";

const diagrams = await getCollection("architecture");

// Map each entry to a relevant Lucide icon name
const entryIcons: Record<string, string> = {
    "cloud-infra": "Cloud",
    integrations: "Share2",
    "security-model": "ShieldCheck",
};

// Map each entry to a subtle accent color
const entryAccents: Record<string, string> = {
    "cloud-infra": "text-brand-400",
    integrations: "text-accent-400",
    "security-model": "text-accent-500",
};
---

<section class="py-20 bg-surface-page relative overflow-hidden">
    <div class="container mx-auto px-4 relative z-10">
        <!-- Section header -->
        <div class="text-center mb-16">
            <span
                class="text-accent-500 font-bold tracking-widest uppercase text-xs"
                >Especificaciones</span
            >
            <h2
                class="text-3xl md:text-5xl font-bold text-fg-primary mt-4 tracking-tight"
            >
                Stack Tecnológico
            </h2>
            <p class="text-fg-secondary mt-4 max-w-2xl mx-auto font-light text-lg">
                Cada componente seleccionado por su rendimiento, seguridad y
                compatibilidad con estándares empresariales.
            </p>
        </div>

        <!-- Specs Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
            {
                diagrams.map((diagram) => {
                    const iconName = entryIcons[diagram.id] || "Cpu";
                    const accentColor = entryAccents[diagram.id] || "text-accent-500";

                    return (
                        <div class="group bg-white border border-neutral-100 hover:border-brand-500 rounded-xl p-6 shadow-sm hover:shadow-xl transition-all duration-300">
                            {/* Card Header */}
                            <div class="flex items-start gap-4 mb-6">
                                <div class="w-12 h-12 rounded-lg bg-surface-sunken border border-border-subtle flex items-center justify-center shrink-0 group-hover:border-accent-500/30 transition-colors">
                                    <Icon
                                        name={iconName}
                                        className={`w-6 h-6 ${accentColor}`}
                                        client:only="react"
                                    />
                                </div>
                                <div>
                                    <h3 class="text-base font-bold text-brand-ink-700 tracking-tight leading-snug">
                                        {diagram.data.title}
                                    </h3>
                                    <span class="text-[10px] font-mono text-neutral-400 uppercase tracking-widest mt-1 block">
                                        {diagram.data.diagramType}
                                    </span>
                                </div>
                            </div>

                            {/* Specs List */}
                            {diagram.data.specs && (
                                <div class="space-y-0">
                                    {diagram.data.specs.map((spec, i) => (
                                        <div
                                            class={`flex items-center justify-between py-3 ${
                                                i < (diagram.data.specs?.length ?? 0) - 1
                                                    ? "border-b border-border-subtle"
                                                    : ""
                                            }`}
                                        >
                                            <div class="flex items-center gap-2">
                                                <span class="w-1 h-1 rounded-full bg-accent-500" />
                                                <span class="text-xs text-fg-secondary font-medium">
                                                    {spec.label}
                                                </span>
                                            </div>
                                            <span class="text-xs font-mono text-fg-primary font-semibold bg-surface-sunken px-2 py-0.5 rounded">
                                                {spec.value}
                                            </span>
                                        </div>
                                    ))}
                                </div>
                            )}

                            {/* Status indicator */}
                            <div class="mt-5 pt-4 border-t border-border-subtle flex items-center gap-2">
                                <span class="w-1.5 h-1.5 rounded-full bg-accent-500 animate-pulse" />
                                <span class="text-[10px] font-mono text-accent-500 uppercase tracking-widest">
                                    Activo
                                </span>
                            </div>
                        </div>
                    );
                })
            }
        </div>
    </div>
</section>
