---

---

<section class="py-24 bg-white relative overflow-hidden">
    <div class="container mx-auto px-4 relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-20">
            <div class="lg:w-1/2">
                <h2
                    class="text-accent-500 font-bold tracking-widest uppercase text-xs mb-4"
                >
                    Infraestructura
                </h2>
                <h3 class="text-3xl md:text-5xl font-bold text-brand-500 mb-6">
                    Arquitectura Híbrida
                </h3>
                <p
                    class="text-fg-secondary mb-8 text-lg font-light leading-relaxed"
                >
                    Procesa documentos donde más te convenga: en la nube con
                    Gemini Flash Lite para velocidad, o localmente con LM Studio
                    para máxima privacidad y control.
                </p>
                <ul class="space-y-4 mb-10">
                    <li class="flex items-center text-fg-primary">
                        <span
                            class="w-1.5 h-1.5 bg-brand-500 rounded-full mr-4"
                        ></span>
                        Motor dual: Cloud (Gemini) + On-Premise (LM Studio)
                    </li>
                    <li class="flex items-center text-fg-primary">
                        <span
                            class="w-1.5 h-1.5 bg-brand-500 rounded-full mr-4"
                        ></span>
                        API RESTful documentada con webhooks
                    </li>
                    <li class="flex items-center text-fg-primary">
                        <span
                            class="w-1.5 h-1.5 bg-brand-500 rounded-full mr-4"
                        ></span>
                        Escaneo directo: cámara, escáner eSCL/AirScan y upload
                    </li>
                </ul>
                <a
                    href="/arquitectura"
                    class="bg-brand-500 text-white px-8 py-4 font-semibold hover:bg-brand-700 transition-colors inline-block text-sm rounded-md"
                >
                    Ver Diagramas Técnicos
                </a>
            </div>
            <div class="lg:w-1/2">
                <!-- MacOS Window with Code -->
                <div class="relative group">
                    <div
                        class="absolute -inset-1 bg-gradient-to-r from-accent-500 to-brand-500 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
                    >
                    </div>
                    <div
                        class="bg-brand-ink-900 rounded-xl overflow-hidden shadow-2xl border border-white/5 relative"
                    >
                        <!-- Mac Header -->
                        <div
                            class="bg-brand-ink-600 px-4 py-3 flex items-center justify-between border-b border-white/5"
                        >
                            <div class="flex gap-2">
                                <div
                                    class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"
                                >
                                </div>
                                <div
                                    class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"
                                >
                                </div>
                                <div
                                    class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"
                                >
                                </div>
                            </div>
                            <div class="text-center">
                                <span
                                    class="text-[10px] text-neutral-400 font-medium tracking-[0.2em] uppercase"
                                    >docscan-ocr.ts</span
                                >
                            </div>
                            <div class="w-10"></div>
                        </div>
                        <!-- Code Area -->
                        <div
                            class="p-8 font-mono text-[13px] leading-relaxed overflow-x-auto"
                        >
                            <pre
                                class="text-neutral-300"><span class="text-accent-200">import</span> &lbrace; <span class="text-brand-400">DocScan</span> &rbrace; <span class="text-accent-200">from</span> <span class="text-brand-200">"@docscan/ocr"</span>;

<span class="text-neutral-500">// OCR Engine Selection</span>
<span class="text-accent-200">const</span> <span class="text-brand-400">engine</span> = <span class="text-accent-200">new</span> <span class="text-brand-400">DocScan</span>(&lbrace;
    <span class="text-neutral-300">provider</span>: <span class="text-brand-200">"dual"</span>,
    <span class="text-neutral-300">cloud</span>: <span class="text-brand-200">"gemini-3.1-flash-lite"</span>,
    <span class="text-neutral-300">local</span>: <span class="text-brand-200">"lm-studio"</span>,
    <span class="text-neutral-300">privacy</span>: <span class="text-accent-200">true</span>
&rbrace;);

<span class="text-accent-200">await</span> <span class="text-brand-400">engine</span>.<span class="text-accent-200">scan</span>(&lbrace;
    <span class="text-neutral-300">source</span>: <span class="text-brand-200">"camera|scanner|upload"</span>,
    <span class="text-neutral-300">extract</span>: <span class="text-brand-200">"text|tables|fields"</span>
&rbrace;);</pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
